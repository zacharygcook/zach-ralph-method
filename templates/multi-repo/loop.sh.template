#!/usr/bin/env bash
# Ralph Wiggum Loop - Autonomous Agent Runner (Multi-Repo Mode)
# Orchestrates work across multiple repositories

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/config.env"
source "$SCRIPT_DIR/lib/ralph-common.sh"

# Project root is parent of .ralph/
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

MAX_SPRINT_ITERATIONS="${MAX_SPRINT_ITERATIONS:-}"
MAX_CHUNK_ITERATIONS="${MAX_CHUNK_ITERATIONS:-}"
AGENT="${RALPH_AGENT:-}"
MODEL="${RALPH_AGENT_MODEL:-}"
CURRENT_SPRINT="${CURRENT_SPRINT:-}"
REPOS="${RALPH_REPOS:-${REPOS:-api frontend}}"
PRIMARY_REPO="${RALPH_PRIMARY_REPO:-${PRIMARY_REPO:-api}}"
HEARTBEAT_SEC="${HEARTBEAT_SEC:-30}"
AGENT_IDLE_TIMEOUT_SEC="${AGENT_IDLE_TIMEOUT_SEC:-0}"
POST_RESULT_IDLE_SEC="${POST_RESULT_IDLE_SEC:-45}"
RALPH_INTERACTIVE="${RALPH_INTERACTIVE:-false}"
RALPH_INTERACTIVE_TIMEOUT_SEC="${RALPH_INTERACTIVE_TIMEOUT_SEC:-20}"
CHUNK_VALIDATION_ENABLED="${RALPH_CHUNK_VALIDATION_ENABLED:-true}"
CHUNK_VALIDATION_COMMAND="${RALPH_CHUNK_VALIDATION_COMMAND:-}"
VALIDATION_HEARTBEAT_SEC="${VALIDATION_HEARTBEAT_SEC:-15}"
VALIDATION_IDLE_TIMEOUT_SEC="${VALIDATION_IDLE_TIMEOUT_SEC:-0}"
ACTIVE_VALIDATION_CHUNK=""
ACTIVE_VALIDATION_ITERATION=""
ACTIVE_VALIDATION_LOG=""
ACTIVE_VALIDATION_PID=""
ACTIVE_VALIDATION_STARTED=""

missing=$(require_commands bash git jq || true)
if [[ -n "$missing" ]]; then
  echo "$missing"
  exit 12
fi
PYTHON_BIN=$(find_python) || exit 12
for budget in "$MAX_SPRINT_ITERATIONS" "$MAX_CHUNK_ITERATIONS"; do
  if [[ ! "$budget" =~ ^[1-9][0-9]*$ ]]; then
    echo "MAX_SPRINT_ITERATIONS and MAX_CHUNK_ITERATIONS must be positive integers"
    exit 12
  fi
done
case "$AGENT" in
  amp|claude|codex|droid|opencode|custom) ;;
  *)
    echo "RALPH_AGENT must explicitly select amp, claude, codex, droid, opencode, or custom"
    exit 12
    ;;
esac
if [[ "$AGENT" == "custom" && -z "${RALPH_AGENT_COMMAND:-}" ]]; then
  echo "RALPH_AGENT_COMMAND is required for the custom harness"
  exit 12
fi
if [[ "$AGENT" != "custom" && -z "$MODEL" ]]; then
  echo "RALPH_AGENT_MODEL is required for the $AGENT harness"
  exit 12
fi
if [[ "$CHUNK_VALIDATION_ENABLED" == "true" && -z "$CHUNK_VALIDATION_COMMAND" ]]; then
  echo "RALPH_CHUNK_VALIDATION_COMMAND is required while chunk validation is enabled"
  exit 12
fi

# ── CLI Flags ──────────────────────────────────────────────
RESUME=false
FORCE_HOOKS=false
for arg in "$@"; do
  case "$arg" in
    --resume) RESUME=true ;;
    --force-hooks) FORCE_HOOKS=true ;;
    *)
      echo "Unknown option: $arg"
      echo "Usage: ./loop.sh [--resume] [--force-hooks]"
      exit 1
      ;;
  esac
done

# ── Sprint Validation ─────────────────────────────────────
SPRINT_DIR="$SCRIPT_DIR/sprints/$CURRENT_SPRINT"
PROMPT_FILE="$SPRINT_DIR/prompt.md"
CHUNKS_FILE="$SPRINT_DIR/chunks.json"
MANIFEST_FILE="$SPRINT_DIR/manifest.json"

if [[ -z "$CURRENT_SPRINT" ]] || [[ ! -d "$SPRINT_DIR" ]]; then
  echo "Error: CURRENT_SPRINT not set or sprint folder not found"
  echo "Set CURRENT_SPRINT in config.env (e.g., CURRENT_SPRINT=1-scaffold-foundation)"
  exit 1
fi

# Validate repos exist
for repo in $REPOS; do
  if [[ ! "$repo" =~ ^[A-Za-z0-9._-]+$ ]]; then
    echo "Error: Invalid repository directory name: $repo"
    exit 14
  fi
  REPO_PATH="$PROJECT_ROOT/$repo"
  if [[ ! -e "$REPO_PATH/.git" ]]; then
    echo "Error: Repo not found or not a git repo: $REPO_PATH"
    exit 1
  fi
done

# ── Run Setup ──────────────────────────────────────────────
RUN_ID=$(date +%Y%m%d-%H%M%S)
LOG_DIR="$SCRIPT_DIR/logs/$CURRENT_SPRINT/run-$RUN_ID"
mkdir -p "$LOG_DIR"

START_TIME=$(now_iso)
ORCHESTRATOR_LOG="$LOG_DIR/orchestrator.log"
EVENT_LOG="$LOG_DIR/events.jsonl"

log_orchestrator() {
  local msg="$1"
  local ts
  ts=$(now_iso)
  echo "[$ts] $msg" | tee -a "$ORCHESTRATOR_LOG"
}

log_event() {
  append_event "$EVENT_LOG" "$1" "$2" "$3"
}

# ── Multi-Repo Helpers ─────────────────────────────────────
get_repo_commit() {
  local repo="$1"
  git -C "$PROJECT_ROOT/$repo" rev-parse HEAD 2>/dev/null || echo "unknown"
}

backup_commit_all_repos() {
  local msg="$1"
  if [[ "${RALPH_AUTO_COMMIT:-false}" == "true" ]]; then
    echo "Refusing RALPH_AUTO_COMMIT=true; use RALPH_AUTO_COMMIT=I_ACCEPT_GIT_ADD_ALL to acknowledge broad staging"
    return 14
  fi
  [[ "${RALPH_AUTO_COMMIT:-false}" == "I_ACCEPT_GIT_ADD_ALL" ]] || return 0
  for repo in $REPOS; do
    git -C "$PROJECT_ROOT/$repo" add -A
    git -C "$PROJECT_ROOT/$repo" commit -m "$msg" -q 2>/dev/null || true
  done
}

get_all_repo_commits() {
  local result="{"
  local first=true
  for repo in $REPOS; do
    local commit
    commit=$(get_repo_commit "$repo")
    if [[ "$first" == "true" ]]; then
      first=false
    else
      result+=","
    fi
    result+="\"$repo\":\"$commit\""
  done
  result+="}"
  echo "$result"
}

finalize_manifest_repos() {
  local end_time
  end_time=$(now_iso)
  for repo in $REPOS; do
    local end_commit
    end_commit=$(get_repo_commit "$repo")
    manifest_update \
      --arg repo "$repo" --arg commit "$end_commit" \
      '.repos[$repo].end_commit = $commit' || true
  done
  manifest_update \
    --arg time "$end_time" \
    '.completed_at = $time | .phase = "chunks_done"' || true
  log_orchestrator "manifest_updated: phase=chunks_done"
  log_event "manifest" "ok" "phase=chunks_done"
}

# ── Manifest Initialization ───────────────────────────────
if [[ ! -f "$MANIFEST_FILE" ]] || ! jq -e '.repos' "$MANIFEST_FILE" >/dev/null 2>&1; then
  # Build repos object with start commits
  REPOS_JSON="{"
  first=true
  for repo in $REPOS; do
    START_COMMIT=$(get_repo_commit "$repo")
    if [[ "$first" == "true" ]]; then
      first=false
    else
      REPOS_JSON+=","
    fi
    REPOS_JSON+="\"$repo\":{\"start_commit\":\"$START_COMMIT\",\"end_commit\":null}"
  done
  REPOS_JSON+="}"

  cat > "$MANIFEST_FILE" <<EOF_MANIFEST
{
  "sprint": "$CURRENT_SPRINT",
  "started_at": "$START_TIME",
  "completed_at": null,
  "iterations": 0,
  "agent_turns": [],
  "repos": $REPOS_JSON,
  "commits": [],
  "validation": {"chunk_attempts": []},
  "phase": "running",
  "hooks": {
    "review": {"status": "pending", "completed_at": null, "reason": null},
    "documentation": {"status": "pending", "completed_at": null, "reason": null},
    "validation": {"status": "pending", "completed_at": null, "reason": null, "phases": {"sprint": {"status":"pending"}, "e2e": {"status":"pending"}}}
  }
}
EOF_MANIFEST
fi

# Normalize manifest schema for older manifests
ensure_manifest_schema() {
  manifest_update_locked "$MANIFEST_FILE" '
    .phase = (.phase // "running")
    | .agent_turns = (.agent_turns // [])
    | .hooks = (.hooks // {})
    | .hooks.review = (.hooks.review // {"status":"pending","completed_at":null,"reason":null})
    | .hooks.documentation = (.hooks.documentation // {"status":"pending","completed_at":null,"reason":null})
    | .validation = (.validation // {"chunk_attempts":[]})
    | .validation.chunk_attempts = (.validation.chunk_attempts // [])
    | .hooks.validation = (.hooks.validation // .hooks.tests // {"status":"pending","completed_at":null,"reason":null})
    | .hooks.validation.reason = (.hooks.validation.reason // null)
    | .hooks.validation.phases = (.hooks.validation.phases // {"sprint":{"status":"pending"},"e2e":{"status":"pending"}})
    | del(.hooks.tests)
  ' || {
    log_orchestrator "ERROR: Failed to normalize manifest schema"
    return 1
  }
}

manifest_update() {
  manifest_update_locked "$MANIFEST_FILE" "$@" || {
    log_orchestrator "ERROR: Manifest update failed"
    return 1
  }
}

# ── Chunk State ────────────────────────────────────────────
all_chunks_pass_fn() {
  all_chunks_pass "$CHUNKS_FILE"
}

passed_chunk_count() {
  count_passed_chunks "$CHUNKS_FILE"
}

passed_chunk_ids() {
  jq -c '[.chunks[] | select(.passes == true) | .id]' "$CHUNKS_FILE"
}

next_incomplete_chunk_id() {
  jq -r '[.chunks[] | select(.passes != true)][0].id // empty' "$CHUNKS_FILE"
}

chunk_turn_count() {
  local chunk_id="$1"
  jq --argjson chunk "$chunk_id" '[.agent_turns[] | select(.chunk_id == $chunk)] | length' "$MANIFEST_FILE"
}

record_agent_turn() {
  local chunk_id="$1" iteration="$2" started_at="$3"
  manifest_update \
    --argjson chunk "$chunk_id" --argjson iter "$iteration" --arg started "$started_at" \
    '.agent_turns += [{chunk_id:$chunk,iteration:$iter,started_at:$started}]'
}

reset_chunk_pass() {
  local chunk_id tmp
  chunk_id="$1"
  tmp="${CHUNKS_FILE}.tmp"
  jq --argjson id "$chunk_id" '(.chunks[] | select(.id == $id) | .passes) = false' "$CHUNKS_FILE" > "$tmp"
  mv "$tmp" "$CHUNKS_FILE"
}

chunk_owner() {
  local chunk_id="$1"
  jq -r --argjson id "$chunk_id" '.chunks[] | select(.id == $id) | .repo' "$CHUNKS_FILE"
}

repos_have_commit_evidence() {
  local chunk_id before after owner repo
  chunk_id="$1"
  before="$2"
  after="$3"
  owner=$(chunk_owner "$chunk_id")
  if [[ "$owner" == "all" || "$owner" == "both" ]]; then
    for repo in $REPOS; do
      jq -ne --arg repo "$repo" --argjson before "$before" --argjson after "$after" '$before[$repo] != $after[$repo]' >/dev/null || return 1
    done
    return 0
  fi
  jq -ne --arg repo "$owner" --argjson before "$before" --argjson after "$after" '$before[$repo] != $after[$repo]' >/dev/null
}

record_chunk_validation() {
  local chunk_id="$1" iteration="$2" status="$3" exit_code="$4" started_at="$5" completed_at="$6" log_path="$7"
  manifest_update --argjson chunk "$chunk_id" --argjson iter "$iteration" --arg status "$status" \
    --argjson exit "$exit_code" --arg started "$started_at" --arg completed "$completed_at" --arg log "$log_path" \
    '.validation.chunk_attempts += [{chunk_id:$chunk,iteration:$iter,status:$status,exit_code:$exit,started_at:$started,completed_at:$completed,log:$log}]' || true
}

run_chunk_validation() {
  local chunk_id iteration validation_log
  local started_at completed_at validation_pid validation_exit=0 validation_status
  chunk_id="$1"
  iteration="$2"
  validation_log="$LOG_DIR/chunk-${chunk_id}-validation-${iteration}.log"
  started_at=$(now_iso)
  ACTIVE_VALIDATION_CHUNK="$chunk_id"
  ACTIVE_VALIDATION_ITERATION="$iteration"
  ACTIVE_VALIDATION_LOG="$validation_log"
  ACTIVE_VALIDATION_STARTED="$started_at"
  log_orchestrator "chunk_validation_started: chunk=$chunk_id iteration=$iteration log=$validation_log"
  log_event "chunk_validation" "running" "chunk=$chunk_id iteration=$iteration"
  (cd "$PROJECT_ROOT" && bash -lc "$CHUNK_VALIDATION_COMMAND") >"$validation_log" 2>&1 &
  validation_pid=$!
  ACTIVE_VALIDATION_PID="$validation_pid"
  monitor_process_with_heartbeat "$validation_pid" "chunk validation=$chunk_id" "$validation_log" \
    "$VALIDATION_HEARTBEAT_SEC" "$VALIDATION_IDLE_TIMEOUT_SEC" "$EVENT_LOG" || validation_exit=$?
  completed_at=$(now_iso)
  if [[ "$validation_exit" -eq 0 ]]; then validation_status="passed"; else validation_status="failed"; fi
  log_orchestrator "chunk_validation_${validation_status}: chunk=$chunk_id iteration=$iteration exit=$validation_exit"
  log_event "chunk_validation" "$validation_status" "chunk=$chunk_id iteration=$iteration exit=$validation_exit"
  record_chunk_validation "$chunk_id" "$iteration" "$validation_status" "$validation_exit" "$started_at" "$completed_at" "$validation_log"
  ACTIVE_VALIDATION_CHUNK=""; ACTIVE_VALIDATION_ITERATION=""; ACTIVE_VALIDATION_LOG=""; ACTIVE_VALIDATION_PID=""; ACTIVE_VALIDATION_STARTED=""
  return "$validation_exit"
}

record_validation_feedback() {
  local chunk_id="$1" iteration="$2" reason="$3" log_path="$4"
  {
    echo ""; echo "## Ralph validation feedback — chunk $chunk_id, iteration $iteration"; echo ""
    echo "- Result: $reason"; echo "- Log: \`$log_path\`"
    echo "- The chunk was reset to \`passes: false\`; inspect the log and repair before claiming completion again."
  } >> "$SPRINT_DIR/SCRATCHPAD.md"
}

handle_loop_signal() {
  local signal_name="$1" exit_code="$2"
  log_orchestrator "signal_received: $signal_name"
  log_event "signal" "interrupted" "$signal_name received"
  if [[ -n "$ACTIVE_VALIDATION_CHUNK" ]]; then
    kill_process_tree "$ACTIVE_VALIDATION_PID"
    reset_chunk_pass "$ACTIVE_VALIDATION_CHUNK"
    record_chunk_validation "$ACTIVE_VALIDATION_CHUNK" "$ACTIVE_VALIDATION_ITERATION" "interrupted" 13 \
      "$ACTIVE_VALIDATION_STARTED" "$(now_iso)" "$ACTIVE_VALIDATION_LOG"
    record_validation_feedback "$ACTIVE_VALIDATION_CHUNK" "$ACTIVE_VALIDATION_ITERATION" \
      "chunk validation was interrupted by $signal_name" "$ACTIVE_VALIDATION_LOG"
  fi
  trap - EXIT
  exit "$exit_code"
}

# ── Next Sprint ────────────────────────────────────────────
get_next_sprint() {
  local current_num next_num candidate
  current_num=$(echo "$CURRENT_SPRINT" | grep -oE '^[0-9]+' || echo "")
  [[ -z "$current_num" ]] && return 0
  next_num=$((current_num + 1))
  for candidate in "$SCRIPT_DIR/sprints/${next_num}-"*; do
    if [[ -d "$candidate" ]]; then
      basename "$candidate"
      return 0
    fi
  done
  return 0
}

offer_next_sprint_prompt() {
  local next_sprint="$1"

  echo ""
  echo "Next sprint available: $next_sprint"
  echo "To start: Update CURRENT_SPRINT=$next_sprint in config.env and run ./loop.sh"
  echo ""

  if [[ "$RALPH_INTERACTIVE" == "true" ]] && [[ -t 0 ]]; then
    if read -r -t "$RALPH_INTERACTIVE_TIMEOUT_SEC" -p "Auto-update config and continue? [y/N] " REPLY; then
      echo
      if [[ $REPLY =~ ^[Yy]$ ]]; then
        echo "Set CURRENT_SPRINT=$next_sprint in $SCRIPT_DIR/config.env, then run ./loop.sh again."
      fi
    else
      echo
      echo "Skipping prompt after timeout (${RALPH_INTERACTIVE_TIMEOUT_SEC}s)."
    fi
  fi
}

# ── Post-Sprint Hooks ─────────────────────────────────────
hooks_completed() {
  [[ "$(jq -r '.phase // ""' "$MANIFEST_FILE" 2>/dev/null || echo "")" == "hooks_done" ]]
}

mark_hooks_phase_done() {
  local now
  now=$(now_iso)
  manifest_update --arg now "$now" '.phase = "hooks_done"' || return 1
  log_orchestrator "manifest_updated: phase=hooks_done"
  log_event "manifest" "ok" "phase=hooks_done"
}

run_post_sprint_hooks() {
  if [[ ! -x "$SCRIPT_DIR/hooks/post-sprint.sh" ]]; then
    log_orchestrator "hooks_missing: $SCRIPT_DIR/hooks/post-sprint.sh"
    return 1
  fi

  log_orchestrator "hooks_started"
  log_event "hooks" "running" "post-sprint start"

  if RALPH_EVENT_LOG="$EVENT_LOG" RALPH_FORCE_HOOKS="$([[ "$FORCE_HOOKS" == "true" ]] && echo 1 || echo 0)" \
    "$SCRIPT_DIR/hooks/post-sprint.sh" "$SPRINT_DIR"; then
    log_orchestrator "hooks_finished: success"
    log_event "hooks" "ok" "post-sprint success"
  else
    log_orchestrator "hooks_finished: partial_or_failed"
    log_event "hooks" "failed" "post-sprint partial_or_failed"
    return 1
  fi
}

# ── Reconciliation ─────────────────────────────────────────
RECONCILIATION_DONE=false
reconcile_completion_state() {
  if [[ "$RECONCILIATION_DONE" == "true" ]]; then
    return 0
  fi
  RECONCILIATION_DONE=true

  ensure_manifest_schema || true

  if ! all_chunks_pass_fn; then
    log_orchestrator "reconcile_skip: chunks_incomplete"
    log_event "reconcile" "skipped" "chunks_incomplete"
    return 0
  fi

  if [[ "$(jq -r '.completed_at // "null"' "$MANIFEST_FILE" 2>/dev/null || echo "null")" == "null" ]]; then
    finalize_manifest_repos || true
  fi

  if hooks_completed && [[ "$FORCE_HOOKS" != "true" ]]; then
    log_orchestrator "reconcile_skip: hooks_already_done"
    log_event "reconcile" "skipped" "hooks_already_done"
    return 0
  fi

  echo ""
  echo "Running post-sprint hooks..."
  run_post_sprint_hooks || return 14

  if jq -e '([.hooks.review.status, .hooks.documentation.status, .hooks.validation.status] | all(. == "done" or . == "skipped"))' "$MANIFEST_FILE" >/dev/null 2>&1; then
    mark_hooks_phase_done || true
    return 0
  fi
  return 14
}

# ── Signal Traps ───────────────────────────────────────────
trap 'handle_loop_signal INT 130' INT
trap 'handle_loop_signal TERM 143' TERM
trap 'reconcile_completion_state' EXIT

# ── Agent Commands ─────────────────────────────────────────
start_stream_sidecar() {
  local formatter_path="${1:-}"
  touch "$LOG_FILE"

  if [[ -n "$formatter_path" ]]; then
    (
      tail -n +1 -f "$LOG_FILE" 2>/dev/null | "$PYTHON_BIN" "$formatter_path"
    ) &
  else
    (
      tail -n +1 -f "$LOG_FILE" 2>/dev/null
    ) &
  fi

  STARTED_SIDECAR_PID="$!"
}

stop_stream_sidecar() {
  local sidecar_pid="${1:-}"
  STOPPED_SIDECAR_EXIT=0
  [[ -z "$sidecar_pid" ]] && return 0

  kill_process_tree "$sidecar_pid"
  # Sidecar termination is expected after agent completion/kill.
  # Keep this function non-fatal under `set -e` and expose exit via variable.
  set +e
  wait "$sidecar_pid" 2>/dev/null
  STOPPED_SIDECAR_EXIT=$?
  set -e
  return 0
}

start_agent_iteration() {
  local formatter_path=""
  local sidecar_pid agent_pid agent_pgid
  : > "$LOG_FILE"

  case "$AGENT" in
    claude)
      formatter_path="$SCRIPT_DIR/format-stream.py"
      ;;
    codex)
      formatter_path="$SCRIPT_DIR/format-codex-stream.py"
      ;;
    amp|opencode|droid)
      formatter_path=""
      ;;
    *) formatter_path="" ;;
  esac

  start_stream_sidecar "$formatter_path"
  sidecar_pid="$STARTED_SIDECAR_PID"

  run_agent "$AGENT" "$PROMPT_FILE" "$PROJECT_ROOT" >"$LOG_FILE" 2>&1 &
  agent_pid=$!
  agent_pgid=$(process_pgid "$agent_pid")

  AGENT_PID="$agent_pid"
  AGENT_PGID="$agent_pgid"
  SIDECAR_PID="$sidecar_pid"

  log_orchestrator "agent_spawned: iteration=$CURRENT_ITERATION agent=$AGENT pid=$AGENT_PID pgid=${AGENT_PGID:-unknown} sidecar_pid=$SIDECAR_PID log=$LOG_FILE"
  log_event "process" "spawned" "iteration=$CURRENT_ITERATION agent_pid=$AGENT_PID agent_pgid=${AGENT_PGID:-unknown} sidecar_pid=$SIDECAR_PID"
}

run_agent_with_watchdog() {
  local agent_exit sidecar_exit

  start_agent_iteration || return $?

  agent_exit=0
  monitor_process_with_heartbeat \
    "$AGENT_PID" \
    "agent iteration=$CURRENT_ITERATION agent=$AGENT" \
    "$LOG_FILE" \
    "$HEARTBEAT_SEC" \
    "$AGENT_IDLE_TIMEOUT_SEC" \
    "$EVENT_LOG" \
    "" \
    "$POST_RESULT_IDLE_SEC" \
    "$AGENT_PID,$SIDECAR_PID" || agent_exit=$?
  stop_stream_sidecar "$SIDECAR_PID"
  sidecar_exit="${STOPPED_SIDECAR_EXIT:-0}"

  if (( sidecar_exit != 0 )); then
    log_orchestrator "sidecar_nonzero_exit: iteration=$CURRENT_ITERATION sidecar_pid=$SIDECAR_PID exit=$sidecar_exit"
    log_event "process" "warning" "iteration=$CURRENT_ITERATION sidecar_pid=$SIDECAR_PID sidecar_exit=$sidecar_exit"
  fi

  log_orchestrator "agent_stream_closed: iteration=$CURRENT_ITERATION agent_pid=$AGENT_PID sidecar_pid=$SIDECAR_PID sidecar_exit=$sidecar_exit"
  log_event "process" "closed" "iteration=$CURRENT_ITERATION agent_pid=$AGENT_PID sidecar_pid=$SIDECAR_PID sidecar_exit=$sidecar_exit"

  return "$agent_exit"
}

# ── Main Loop ──────────────────────────────────────────────
echo "Starting Ralph loop (multi-repo): agent=$AGENT, model=${MODEL:-custom-command}"
echo "Turn budgets: sprint=$MAX_SPRINT_ITERATIONS, per-chunk=$MAX_CHUNK_ITERATIONS"
echo "Sprint: $CURRENT_SPRINT"
echo "Repos: $REPOS"
echo "Project root: $PROJECT_ROOT"
echo "Logs: $LOG_DIR"
echo "---"
log_orchestrator "loop_started: agent=$AGENT model=${MODEL:-custom-command} sprint=$CURRENT_SPRINT repos=$REPOS max_sprint_iterations=$MAX_SPRINT_ITERATIONS max_chunk_iterations=$MAX_CHUNK_ITERATIONS resume=$RESUME force_hooks=$FORCE_HOOKS"
log_event "loop" "started" "agent=$AGENT model=${MODEL:-custom-command} sprint=$CURRENT_SPRINT"

ensure_manifest_schema

# Pre-check: all chunks already done
if all_chunks_pass_fn; then
  echo "All chunks already complete! Skipping to post-sprint hooks..."
  echo ""
  log_orchestrator "precheck: all_chunks_pass=true"
  log_event "precheck" "ok" "all_chunks_pass=true"

  if ! reconcile_completion_state; then
    trap - EXIT
    exit 14
  fi

  NEXT_SPRINT=$(get_next_sprint)
  if [[ -n "$NEXT_SPRINT" ]]; then
    offer_next_sprint_prompt "$NEXT_SPRINT"
  else
    echo "No next sprint found. Create one with /ralph-sprint"
  fi

  exit 0
fi

# Turn budgets persist across every invocation, not only --resume runs.
RECORDED_TURNS=$(jq -r '[.iterations // 0, ((.agent_turns // []) | length)] | max' "$MANIFEST_FILE" 2>/dev/null || echo 0)
START_ITERATION=$((RECORDED_TURNS + 1))
if (( START_ITERATION > MAX_SPRINT_ITERATIONS )); then
  echo "Sprint turn budget ($MAX_SPRINT_ITERATIONS) was already exhausted"
  log_orchestrator "max_sprint_iterations_reached: $MAX_SPRINT_ITERATIONS"
  log_event "budget" "exhausted" "sprint_max=$MAX_SPRINT_ITERATIONS"
  exit 2
fi

for i in $(seq "$START_ITERATION" "$MAX_SPRINT_ITERATIONS"); do
  CURRENT_ITERATION="$i"
  echo "[Iteration $i/$MAX_SPRINT_ITERATIONS]"
  log_orchestrator "iteration_started: $i"
  log_event "iteration" "started" "iteration=$i"

  LOG_FILE="$LOG_DIR/iteration-$i.log"
  SUMMARY_LOG="$LOG_DIR/iteration-$i.summary.log"
  export SUMMARY_LOG

  BEFORE_PASS_IDS=$(passed_chunk_ids)
  EXPECTED_CHUNK_ID=$(next_incomplete_chunk_id)
  CHUNK_TURNS=$(chunk_turn_count "$EXPECTED_CHUNK_ID")
  if (( CHUNK_TURNS >= MAX_CHUNK_ITERATIONS )); then
    echo "Chunk $EXPECTED_CHUNK_ID reached its $MAX_CHUNK_ITERATIONS-turn budget"
    log_orchestrator "chunk_turn_budget_reached: chunk=$EXPECTED_CHUNK_ID turns=$CHUNK_TURNS limit=$MAX_CHUNK_ITERATIONS"
    log_event "budget" "exhausted" "chunk=$EXPECTED_CHUNK_ID turns=$CHUNK_TURNS limit=$MAX_CHUNK_ITERATIONS"
    exit 15
  fi
  record_agent_turn "$EXPECTED_CHUNK_ID" "$i" "$(now_iso)"
  BEFORE_REPO_COMMITS=$(get_all_repo_commits)

  set +e
  run_agent_with_watchdog
  AGENT_EXIT=$?
  set -e

  log_orchestrator "agent_done: iteration=$i log=$LOG_FILE exit=$AGENT_EXIT"
  log_event "iteration" "agent_done" "iteration=$i exit=$AGENT_EXIT"

  # ── State-Delta Completion Validation ──────────────────
  AFTER_PASS_IDS=$(passed_chunk_ids)
  NEWLY_PASSED=$(jq -nc --argjson before "$BEFORE_PASS_IDS" --argjson after "$AFTER_PASS_IDS" '$after - $before')
  REMOVED_PASSES=$(jq -nc --argjson before "$BEFORE_PASS_IDS" --argjson after "$AFTER_PASS_IDS" '$before - $after')
  NEW_PASS_COUNT=$(jq 'length' <<<"$NEWLY_PASSED")
  REMOVED_PASS_COUNT=$(jq 'length' <<<"$REMOVED_PASSES")
  NEW_CHUNK_ID=$(jq -r '.[0] // empty' <<<"$NEWLY_PASSED")
  TRANSITION_VALID=false
  if [[ "$NEW_PASS_COUNT" -eq 1 && "$REMOVED_PASS_COUNT" -eq 0 && "$NEW_CHUNK_ID" == "$EXPECTED_CHUNK_ID" ]]; then
    TRANSITION_VALID=true
  fi

  COMPLETION_SCOPE=$(detect_completion_scope "$LOG_FILE")
  COMPLETION_SIGNAL=false

  if [[ "$COMPLETION_SCOPE" == "sprint" || "$COMPLETION_SCOPE" == "chunk" || "$COMPLETION_SCOPE" == "legacy_chunk" ]]; then
    if [[ "$TRANSITION_VALID" == "true" ]]; then
      COMPLETION_SIGNAL=true
      log_orchestrator "completion_candidate_detected: iteration=$i scope=$COMPLETION_SCOPE chunk=$NEW_CHUNK_ID"
    else
      log_orchestrator "completion_signal_ignored: iteration=$i scope=$COMPLETION_SCOPE newly_passed=$NEWLY_PASSED removed=$REMOVED_PASSES expected=$EXPECTED_CHUNK_ID"
      log_event "completion" "ignored" "iteration=$i invalid chunk transition"
    fi
  fi

  if [[ "$TRANSITION_VALID" != "true" && "$NEW_PASS_COUNT" -gt 0 ]]; then
    for changed_chunk in $(jq -r '.[]' <<<"$NEWLY_PASSED"); do reset_chunk_pass "$changed_chunk"; done
  fi

  if [[ "$COMPLETION_SIGNAL" == "true" ]]; then
    VALIDATION_LOG="$LOG_DIR/chunk-${NEW_CHUNK_ID}-validation-${i}.log"
    if [[ "$CHUNK_VALIDATION_ENABLED" == "true" ]] && ! run_chunk_validation "$NEW_CHUNK_ID" "$i"; then
      reset_chunk_pass "$NEW_CHUNK_ID"
      record_validation_feedback "$NEW_CHUNK_ID" "$i" "configured chunk validation failed" "$VALIDATION_LOG"
      echo "Chunk $NEW_CHUNK_ID validation failed; the completion claim was rejected."
      tail -n 20 "$VALIDATION_LOG" 2>/dev/null || true
      manifest_update --argjson iter "$i" '.iterations = $iter' || true
      sleep 2
      continue
    fi

    AFTER_REPO_COMMITS=$(get_all_repo_commits)
    if [[ "${RALPH_AUTO_COMMIT:-false}" != "I_ACCEPT_GIT_ADD_ALL" ]] && ! repos_have_commit_evidence "$NEW_CHUNK_ID" "$BEFORE_REPO_COMMITS" "$AFTER_REPO_COMMITS"; then
      reset_chunk_pass "$NEW_CHUNK_ID"
      record_validation_feedback "$NEW_CHUNK_ID" "$i" "validation passed but the chunk-owned repositories have no new commit" "$VALIDATION_LOG"
      log_orchestrator "completion_rejected: chunk=$NEW_CHUNK_ID iteration=$i reason=no_new_commit owner=$(chunk_owner "$NEW_CHUNK_ID") before=$BEFORE_REPO_COMMITS after=$AFTER_REPO_COMMITS"
      log_event "completion" "rejected" "chunk=$NEW_CHUNK_ID iteration=$i reason=no_new_commit"
      echo "Chunk $NEW_CHUNK_ID validation passed, but required repository commits were not created."
      manifest_update --argjson iter "$i" '.iterations = $iter' || true
      sleep 2
      continue
    fi

    echo ""
    echo "=========================================="
    echo "Chunk completed in iteration $i"
    echo "=========================================="

    # Backup commit in all repos
    backup_commit_all_repos "ralph: chunk completed (iteration $i)" || exit $?

    REPO_COMMITS=$(get_all_repo_commits)
    CHUNK_ID="$NEW_CHUNK_ID"
    manifest_update \
      --argjson commits "$REPO_COMMITS" --argjson chunk "$CHUNK_ID" --argjson iter "$i" \
      '.commits += [{"chunk_id": $chunk, "iteration": $iter, "repos": $commits}] | .iterations = $iter' \
      || true

    if all_chunks_pass_fn; then
      echo "All chunks complete! Sprint finished."
      echo ""
      log_orchestrator "sprint_chunks_complete: iteration=$i"
      log_event "sprint" "chunks_done" "iteration=$i"

      if ! reconcile_completion_state; then
        trap - EXIT
        exit 14
      fi

      NEXT_SPRINT=$(get_next_sprint)
      if [[ -n "$NEXT_SPRINT" ]]; then
        offer_next_sprint_prompt "$NEXT_SPRINT"
      else
        echo "No next sprint found. Create one with /ralph-sprint"
      fi

      trap - EXIT
      exit 0
    fi

    echo "Chunk done. Continuing to next chunk with fresh context..."
    sleep 2
    continue
  fi

  # Check for blocked
  if grep -q "<blocked>" "$LOG_FILE"; then
    REASON=$(sed -n 's/.*<blocked>\(.*\)<\/blocked>.*/\1/p' "$LOG_FILE" | head -1)
    REASON="${REASON:-unknown}"
    echo "Agent blocked: $REASON"
    log_orchestrator "blocked: iteration=$i reason=$REASON"
    log_event "iteration" "blocked" "iteration=$i reason=$REASON"
    exit 14
  fi

  manifest_update --argjson iter "$i" '.iterations = (if (.iterations // 0) < $iter then $iter else .iterations end)' || true

  # Backup commit for incomplete iterations
  backup_commit_all_repos "ralph: iteration $i" || exit $?

  echo "Iteration $i complete, continuing..."
  log_orchestrator "iteration_complete: $i"
  log_event "iteration" "complete" "iteration=$i"
  sleep 2
done

echo "Sprint turn budget ($MAX_SPRINT_ITERATIONS) reached without completion"
log_orchestrator "max_sprint_iterations_reached: $MAX_SPRINT_ITERATIONS"
log_event "budget" "exhausted" "sprint_max=$MAX_SPRINT_ITERATIONS"
exit 2
