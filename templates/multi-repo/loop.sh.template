#!/usr/bin/env bash
# Ralph Wiggum Loop - Autonomous Agent Runner (Multi-Repo Mode)
# Orchestrates work across multiple repositories

set -euo pipefail

# Load config
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/config.env"

# Project root is parent of .ralph/
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

# Defaults
MAX_ITERATIONS="${MAX_ITERATIONS:-30}"
AGENT="${AGENT:-claude}"
CURRENT_SPRINT="${CURRENT_SPRINT:-}"
REPOS="${REPOS:-api frontend}"
PRIMARY_REPO="${PRIMARY_REPO:-api}"
SPRINT_DIR="$SCRIPT_DIR/sprints/$CURRENT_SPRINT"
PROMPT_FILE="$SPRINT_DIR/prompt.md"
CHUNKS_FILE="$SPRINT_DIR/chunks.json"

# Validate sprint exists
if [[ -z "$CURRENT_SPRINT" ]] || [[ ! -d "$SPRINT_DIR" ]]; then
  echo "Error: CURRENT_SPRINT not set or sprint folder not found"
  echo "Set CURRENT_SPRINT in config.env (e.g., CURRENT_SPRINT=1-scaffold-foundation)"
  exit 1
fi

# Validate repos exist
for repo in $REPOS; do
  REPO_PATH="$PROJECT_ROOT/$repo"
  if [[ ! -d "$REPO_PATH/.git" ]]; then
    echo "Error: Repo not found or not a git repo: $REPO_PATH"
    exit 1
  fi
done

# Create timestamped log directory for this run
RUN_ID=$(date +%Y%m%d-%H%M%S)
LOG_DIR="$SCRIPT_DIR/logs/$CURRENT_SPRINT/run-$RUN_ID"
mkdir -p "$LOG_DIR"

# Manifest file for tracking commits
MANIFEST_FILE="$SPRINT_DIR/manifest.json"
START_TIME=$(date -Iseconds)

# Get start commit for a repo
get_repo_commit() {
  local repo="$1"
  cd "$PROJECT_ROOT/$repo" && git rev-parse HEAD 2>/dev/null || echo "unknown"
}

# Initialize manifest if sprint just starting
if [[ ! -f "$MANIFEST_FILE" ]] || ! jq -e '.repos' "$MANIFEST_FILE" >/dev/null 2>&1; then
  # Build repos object with start commits
  REPOS_JSON="{"
  first=true
  for repo in $REPOS; do
    START_COMMIT=$(get_repo_commit "$repo")
    if [[ "$first" == "true" ]]; then
      first=false
    else
      REPOS_JSON+=","
    fi
    REPOS_JSON+="\"$repo\":{\"start_commit\":\"$START_COMMIT\",\"end_commit\":null}"
  done
  REPOS_JSON+="}"

  cat > "$MANIFEST_FILE" << EOF
{
  "sprint": "$CURRENT_SPRINT",
  "started_at": "$START_TIME",
  "completed_at": null,
  "iterations": 0,
  "repos": $REPOS_JSON,
  "commits": []
}
EOF
fi

# Create SCRATCHPAD.md if it doesn't exist yet
SCRATCHPAD_FILE="$SPRINT_DIR/SCRATCHPAD.md"
if [[ ! -f "$SCRATCHPAD_FILE" ]]; then
  cat > "$SCRATCHPAD_FILE" << EOF
# Sprint: $CURRENT_SPRINT — Agent Scratchpad

> This file persists between iterations. Each agent should READ this first and APPEND learnings before finishing.

---

EOF
  echo "Created SCRATCHPAD.md for cross-iteration knowledge transfer"
fi

# Check if all chunks pass
all_chunks_pass() {
  ! grep -q '"passes": false' "$CHUNKS_FILE"
}

# Get next sprint name (increment number prefix)
get_next_sprint() {
  local current_num=$(echo "$CURRENT_SPRINT" | grep -oE '^[0-9]+')
  local next_num=$((current_num + 1))
  ls "$SCRIPT_DIR/sprints/" 2>/dev/null | grep "^${next_num}-" | head -1
}

# Backup commits in all repos
backup_commit_all_repos() {
  local msg="$1"
  for repo in $REPOS; do
    cd "$PROJECT_ROOT/$repo"
    git add -A
    git commit -m "$msg" -q 2>/dev/null || true
  done
}

# Get current commits for all repos as JSON object
get_all_repo_commits() {
  local result="{"
  local first=true
  for repo in $REPOS; do
    local commit=$(get_repo_commit "$repo")
    if [[ "$first" == "true" ]]; then
      first=false
    else
      result+=","
    fi
    result+="\"$repo\":\"$commit\""
  done
  result+="}"
  echo "$result"
}

# Finalize manifest with end commits
finalize_manifest() {
  local end_time=$(date -Iseconds)
  for repo in $REPOS; do
    local end_commit=$(get_repo_commit "$repo")
    jq --arg repo "$repo" --arg commit "$end_commit" \
      '.repos[$repo].end_commit = $commit' \
      "$MANIFEST_FILE" > "$MANIFEST_FILE.tmp" && mv "$MANIFEST_FILE.tmp" "$MANIFEST_FILE"
  done
  jq --arg time "$end_time" '.completed_at = $time' \
    "$MANIFEST_FILE" > "$MANIFEST_FILE.tmp" && mv "$MANIFEST_FILE.tmp" "$MANIFEST_FILE"
}

# Agent command builders
run_claude() {
  cd "$PROJECT_ROOT"  # Run from project root for multi-repo access
  claude --dangerously-skip-permissions -p "$(cat "$PROMPT_FILE")" \
    --output-format=stream-json --include-partial-messages --verbose 2>&1 \
    | tee "$LOG_FILE" \
    | python3 "$SCRIPT_DIR/format-stream.py"
}

run_codex() {
  cd "$PROJECT_ROOT"
  codex exec --full-auto --json "$(cat "$PROMPT_FILE")" 2>&1 \
    | tee "$LOG_FILE" \
    | python3 "$SCRIPT_DIR/format-codex-stream.py"
}

run_amp() {
  cd "$PROJECT_ROOT"
  amp run --autonomous --prompt-file "$PROMPT_FILE" 2>&1
}

run_opencode() {
  cd "$PROJECT_ROOT"
  opencode --auto --prompt "$PROMPT_FILE" 2>&1
}

run_droid() {
  cd "$PROJECT_ROOT"
  droid exec --auto high -f "$PROMPT_FILE" 2>&1
}

# Main loop
echo "Starting Ralph loop (multi-repo): agent=$AGENT, max=$MAX_ITERATIONS"
echo "Sprint: $CURRENT_SPRINT"
echo "Repos: $REPOS"
echo "Project root: $PROJECT_ROOT"
echo "Logs: $LOG_DIR"
echo "---"

# Pre-check: if all chunks already pass, skip agent and go straight to hooks
if all_chunks_pass; then
  echo "All chunks already complete! Skipping to post-sprint hooks..."
  echo ""

  finalize_manifest

  if [[ -x "$SCRIPT_DIR/hooks/post-sprint.sh" ]]; then
    echo "Running post-sprint hooks..."
    "$SCRIPT_DIR/hooks/post-sprint.sh" "$SPRINT_DIR"
  fi

  NEXT_SPRINT=$(get_next_sprint)
  if [[ -n "$NEXT_SPRINT" ]]; then
    echo ""
    echo "Next sprint available: $NEXT_SPRINT"
    echo "To start: Update CURRENT_SPRINT=$NEXT_SPRINT in config.env and run ./loop.sh"
    echo ""
    if [[ -t 0 ]]; then
      read -p "Auto-update config and continue? [y/N] " -n 1 -r
      echo
      if [[ $REPLY =~ ^[Yy]$ ]]; then
        sed -i "s/^CURRENT_SPRINT=.*/CURRENT_SPRINT=$NEXT_SPRINT/" "$SCRIPT_DIR/config.env"
        echo "Updated CURRENT_SPRINT to $NEXT_SPRINT"
        echo "Run ./loop.sh again to start."
      fi
    fi
  else
    echo "No next sprint found. Create one with /ralph-sprint"
  fi

  exit 0
fi

for i in $(seq 1 "$MAX_ITERATIONS"); do
  echo "[Iteration $i/$MAX_ITERATIONS]"

  LOG_FILE="$LOG_DIR/iteration-$i.log"
  SUMMARY_LOG="$LOG_DIR/iteration-$i.summary.log"
  export SUMMARY_LOG

  # Run agent (allow non-zero exit - we check log for completion signals)
  case "$AGENT" in
    claude)   run_claude || true ;;
    codex)    run_codex || true ;;
    amp)      run_amp | tee "$LOG_FILE" || true ;;
    opencode) run_opencode | tee "$LOG_FILE" || true ;;
    droid)    run_droid | tee "$LOG_FILE" || true ;;
    *) echo "Unknown agent: $AGENT"; exit 1 ;;
  esac

  # Check for chunk completion
  if grep -q "RALPH_COMPLETE" "$LOG_FILE"; then
    echo ""
    echo "=========================================="
    echo "Chunk completed in iteration $i"
    echo "=========================================="

    # Backup commit in all repos (no-op if agent already committed)
    backup_commit_all_repos "ralph: chunk completed (iteration $i)"

    # Record commits in manifest
    REPO_COMMITS=$(get_all_repo_commits)
    CHUNK_ID=$(jq '[.chunks[] | select(.passes == true)] | length' "$CHUNKS_FILE" 2>/dev/null || echo "0")
    jq --argjson commits "$REPO_COMMITS" --argjson chunk "$CHUNK_ID" --argjson iter "$i" \
      '.commits += [{"chunk_id": $chunk, "iteration": $iter, "repos": $commits}] | .iterations = $iter' \
      "$MANIFEST_FILE" > "$MANIFEST_FILE.tmp" && mv "$MANIFEST_FILE.tmp" "$MANIFEST_FILE"

    # Check if ALL chunks now pass
    if all_chunks_pass; then
      echo "All chunks complete! Sprint finished."
      echo ""

      finalize_manifest

      if [[ -x "$SCRIPT_DIR/hooks/post-sprint.sh" ]]; then
        echo ""
        echo "Running post-sprint hooks..."
        "$SCRIPT_DIR/hooks/post-sprint.sh" "$SPRINT_DIR"
      fi

      NEXT_SPRINT=$(get_next_sprint)
      if [[ -n "$NEXT_SPRINT" ]]; then
        echo ""
        echo "Next sprint available: $NEXT_SPRINT"
        echo "To start: Update CURRENT_SPRINT=$NEXT_SPRINT in config.env and run ./loop.sh"
        echo ""
        if [[ -t 0 ]]; then
          read -p "Auto-update config and continue? [y/N] " -n 1 -r
          echo
          if [[ $REPLY =~ ^[Yy]$ ]]; then
            sed -i "s/^CURRENT_SPRINT=.*/CURRENT_SPRINT=$NEXT_SPRINT/" "$SCRIPT_DIR/config.env"
            echo "Updated CURRENT_SPRINT to $NEXT_SPRINT"
            echo "Run ./loop.sh again to start."
          fi
        fi
      else
        echo "No next sprint found. Create one with /ralph-sprint"
      fi

      exit 0
    fi

    echo "Chunk done. Continuing to next chunk with fresh context..."
    sleep 2
    continue
  fi

  # Check for blocked
  if grep -q "<blocked>" "$LOG_FILE"; then
    REASON=$(grep -oP '(?<=<blocked>).*(?=</blocked>)' "$LOG_FILE" || echo "unknown")
    echo "Agent blocked: $REASON"
    exit 1
  fi

  # Backup commit for incomplete iterations
  backup_commit_all_repos "ralph: iteration $i"

  echo "Iteration $i complete, continuing..."
  sleep 2
done

echo "Max iterations ($MAX_ITERATIONS) reached without completion"
exit 2
