# Ralph Loop Configuration (Multi-Repo Mode)

# Agent to use: claude, codex, amp, opencode, droid
AGENT=claude

# Maximum iterations before stopping (safety limit)
MAX_ITERATIONS=30

# Current sprint folder (under sprints/)
# Example: CURRENT_SPRINT=1-scaffold-foundation
CURRENT_SPRINT=

# ===== Multi-Repo Configuration =====

# Space-separated list of repo directory names
# These must be sibling directories to the parent .ralph/ folder
REPOS="api frontend"

# Primary repo (used when operation only affects one repo)
PRIMARY_REPO=api

# Repo paths (relative to SCRIPT_DIR parent)
# These are auto-computed but can be overridden
# API_ROOT="$SCRIPT_DIR/../api"
# FRONTEND_ROOT="$SCRIPT_DIR/../frontend"

# ===== Heartbeat & Monitoring =====
# Seconds between heartbeat events in event log (0=disabled)
HEARTBEAT_SEC=30
# Kill agent iteration if log file stops growing for this many seconds (0=disabled)
# Recommend: leave at 0 unless you hit "result printed but loop stuck" failures
AGENT_IDLE_TIMEOUT_SEC=0

# ===== Hook Monitoring =====
# Heartbeat interval for post-sprint hooks
HOOK_HEARTBEAT_SEC=30
# Kill hook if idle for this many seconds (0=disabled)
HOOK_IDLE_TIMEOUT_SEC=0
# Backend test idle timeout (0=disabled)
BACKEND_TEST_IDLE_TIMEOUT_SEC=0
# E2E test idle timeout (0=disabled)
E2E_IDLE_TIMEOUT_SEC=0

# ===== Interactive Prompts =====
# Whether to offer interactive prompts (e.g., auto-continue to next sprint)
# Set to true only when running in an interactive terminal
RALPH_INTERACTIVE=false
# Timeout for interactive prompts before auto-skipping
RALPH_INTERACTIVE_TIMEOUT_SEC=20
