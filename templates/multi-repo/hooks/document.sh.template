#!/usr/bin/env bash
# Documentation Update Hook (Multi-Repo) - Hybrid approach.

set -euo pipefail

SPRINT_DIR="$1"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
MANIFEST="$SPRINT_DIR/manifest.json"

source "$SCRIPT_DIR/lib/ralph-common.sh"
source "$SCRIPT_DIR/config.env"
REPOS="${REPOS:-api frontend}"

EVENT_LOG="${RALPH_EVENT_LOG:-$SPRINT_DIR/hooks.events.jsonl}"
EXIT_DEP_MISSING=12
EXIT_VALIDATION=14

log_event() {
  append_event "$EVENT_LOG" "$1" "$2" "$3"
}

run_claude_with_live_log() {
  local prompt="$1"
  local log_file="$2"
  local sidecar_pid claude_pid claude_exit sidecar_exit

  : > "$log_file"
  tail -n +1 -f "$log_file" 2>/dev/null &
  sidecar_pid=$!

  cd "$PROJECT_ROOT" && claude --dangerously-skip-permissions -p "$prompt" >"$log_file" 2>&1 &
  claude_pid=$!

  log_event "process" "spawned" "hook=document claude_pid=$claude_pid sidecar_pid=$sidecar_pid"

  set +e
  wait "$claude_pid"
  claude_exit=$?
  kill_process_tree "$sidecar_pid"
  wait "$sidecar_pid" 2>/dev/null
  sidecar_exit=$?
  set -e

  log_event "process" "closed" "hook=document claude_pid=$claude_pid sidecar_pid=$sidecar_pid sidecar_exit=$sidecar_exit claude_exit=$claude_exit"
  return "$claude_exit"
}

preflight() {
  local missing
  missing=$(require_commands jq claude || true)
  if [[ -n "$missing" ]]; then
    echo "$missing"
    log_event "document" "failed" "dependency_missing: $missing"
    return "$EXIT_DEP_MISSING"
  fi
  return 0
}

if [[ ! -f "$MANIFEST" ]]; then
  echo "ERROR: Manifest not found: $MANIFEST"
  log_event "document" "failed" "manifest_missing"
  exit "$EXIT_VALIDATION"
fi

preflight || exit $?

SPRINT_NAME=$(jq -r '.sprint' "$MANIFEST")
SPRINT_NUM=$(echo "$SPRINT_NAME" | grep -oE '^[0-9]+' || echo "")
DOC_LOG="$SPRINT_DIR/document.log"

# Sprint summary goes in the sprint folder itself (no global docs in parent)
SPRINT_DOC_FILE="$SPRINT_DIR/SUMMARY.md"

echo "Updating documentation for sprint: $SPRINT_NAME"
echo "Sprint summary: $SPRINT_DOC_FILE"
echo "Repos: $REPOS"
log_event "document" "running" "start sprint=$SPRINT_NAME"

CHUNKS_FILE="$SPRINT_DIR/chunks.json"
CHUNKS_CONTENT=""
if [[ -f "$CHUNKS_FILE" ]]; then
  CHUNKS_CONTENT=$(cat "$CHUNKS_FILE")
fi

COMMITS=""
for repo in $REPOS; do
  REPO_COMMITS=$(jq -r ".commits[].repos.$repo // empty" "$MANIFEST" 2>/dev/null | grep -v null | head -5)
  if [[ -n "$REPO_COMMITS" ]]; then
    COMMITS+="### $repo commits
$REPO_COMMITS

"
  fi
done

MODIFIED_REPOS=$(jq -r '.chunks[].repo // empty' "$CHUNKS_FILE" 2>/dev/null | sort -u || echo "")
if [[ -z "$MODIFIED_REPOS" ]]; then
  MODIFIED_REPOS="$REPOS"
fi

ARTIFACT_INFO=""
for repo in $MODIFIED_REPOS; do
  if [[ "$repo" == "both" ]]; then
    continue
  fi
  REPO_ARTIFACTS=$(jq -r --arg repo "$repo" '.chunks[] | select(.repo == $repo) | .artifacts[]? // empty' "$CHUNKS_FILE" 2>/dev/null | sort -u)
  if [[ -n "$REPO_ARTIFACTS" ]]; then
    ARTIFACT_INFO+="### $repo files
\`\`\`
$REPO_ARTIFACTS
\`\`\`

"
  fi
done

REPO_DOCS=""
for repo in $REPOS; do
  CLAUDE_MD="$PROJECT_ROOT/$repo/CLAUDE.md"
  if [[ -f "$CLAUDE_MD" ]]; then
    REPO_DOCS+="### $repo/CLAUDE.md (first 50 lines)
\`\`\`markdown
$(head -50 "$CLAUDE_MD")
\`\`\`

"
  fi
done

PROMPT_TEMPLATE=$(cat "$SCRIPT_DIR/prompts/document.md")

FULL_PROMPT=$(cat <<EOF_PROMPT
$PROMPT_TEMPLATE

## Sprint: $SPRINT_NAME (Sprint $SPRINT_NUM)

## Multi-Repo Project

This is a multi-repo project. Update documentation in each modified repo.

**IMPORTANT**: Always \`cd\` into the repo directory before running git commands!

## Chunks Completed:
\`\`\`json
$CHUNKS_CONTENT
\`\`\`

## Commits (per repo):
$COMMITS

## Files Modified by Repo:
$ARTIFACT_INFO

## Existing CLAUDE.md Files:
$REPO_DOCS

## Output Locations:
1. Sprint summary: $SPRINT_DOC_FILE
2. Per-repo docs: Update each repo's CLAUDE.md as needed

## Instructions:
1. Create the sprint summary at $SPRINT_DOC_FILE (concise, 50-100 lines)
2. Update CLAUDE.md in each modified repo if the sprint added:
   - New commands or scripts
   - New patterns or conventions
   - New features to document
3. Do NOT add "Generated with" or "Co-Authored-By" lines
4. Commit to each repo that was updated:
   - \`cd api && git add -A && git commit -m "docs: update for sprint $SPRINT_NUM"\`
   - \`cd frontend && git add -A && git commit -m "docs: update for sprint $SPRINT_NUM"\`
EOF_PROMPT
)

set +e
run_claude_with_live_log "$FULL_PROMPT" "$DOC_LOG"
DOC_EXIT=$?
set -e

if [[ "$DOC_EXIT" -ne 0 ]]; then
  echo "WARNING: Claude documentation generation exited with non-zero status"
  log_event "document" "failed" "claude_exit=$DOC_EXIT"
else
  log_event "document" "ok" "claude_exit=0"
fi

echo ""
if [[ -f "$SPRINT_DOC_FILE" ]]; then
  echo "Sprint summary created: $SPRINT_DOC_FILE"
else
  echo "WARNING: Sprint summary not created at $SPRINT_DOC_FILE"
fi

echo "Documentation update complete. See $DOC_LOG for details."
exit "$DOC_EXIT"
