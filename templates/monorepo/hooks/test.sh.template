#!/usr/bin/env bash
# Test Suite Generation Hook - phase-aware and rerun-safe.

set -euo pipefail

SPRINT_DIR="$1"
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
PROJECT_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
MANIFEST="$SPRINT_DIR/manifest.json"

source "$SCRIPT_DIR/lib/ralph-common.sh"

EVENT_LOG="${RALPH_EVENT_LOG:-$SPRINT_DIR/hooks.events.jsonl}"
HEARTBEAT_SEC="${HOOK_HEARTBEAT_SEC:-30}"
BACKEND_TEST_IDLE_TIMEOUT_SEC="${BACKEND_TEST_IDLE_TIMEOUT_SEC:-180}"
E2E_IDLE_TIMEOUT_SEC="${E2E_IDLE_TIMEOUT_SEC:-0}"
POST_RESULT_IDLE_SEC="${POST_RESULT_IDLE_SEC:-45}"
GENERATE_IDLE_TIMEOUT_SEC="${GENERATE_IDLE_TIMEOUT_SEC:-0}"

EXIT_OK=0
EXIT_TIMEOUT=10
EXIT_IDLE_TIMEOUT=11
EXIT_DEP_MISSING=12
EXIT_INTERRUPTED=13
EXIT_VALIDATION=14

PHASE_GENERATE="generate_tests"
PHASE_VERIFY="verify_backend_tests"
PHASE_E2E="run_e2e"

log_event() {
  append_event "$EVENT_LOG" "$1" "$2" "$3"
}

manifest_update() {
  manifest_update_locked "$MANIFEST" "$@" >/dev/null 2>&1 || return 1
}

update_phase() {
  local phase="$1"
  local status="$2"
  local reason="${3:-null}"
  local now
  now=$(now_iso)

  manifest_update \
    --arg phase "$phase" \
    --arg status "$status" \
    --arg now "$now" \
    --arg reason "$reason" \
    '
      .hooks.tests = (.hooks.tests // {"status":"pending","completed_at":null,"reason":null,"phases":{}})
      | .hooks.tests.phases = (.hooks.tests.phases // {})
      | .hooks.tests.phases[$phase] = (.hooks.tests.phases[$phase] // {"status":"pending","completed_at":null,"reason":null})
      | .hooks.tests.phases[$phase].status = $status
      | .hooks.tests.phases[$phase].reason = (if $reason == "null" then null else $reason end)
      | .hooks.tests.phases[$phase].completed_at = (if ($status == "done" or $status == "skipped") then $now else .hooks.tests.phases[$phase].completed_at end)
      | .hooks.tests.reason = (if ($status == "failed") then (if $reason == "null" then "phase_failed" else $reason end) else .hooks.tests.reason end)
    '
}

phase_status() {
  local phase="$1"
  jq -r --arg phase "$phase" '.hooks.tests.phases[$phase].status // "pending"' "$MANIFEST" 2>/dev/null || echo "pending"
}

phase_is_complete() {
  local phase="$1"
  local status
  status=$(phase_status "$phase")
  [[ "$status" == "done" ]] || [[ "$status" == "skipped" ]]
}

run_monitored_command() {
  local label="$1"
  local log_file="$2"
  local idle_timeout="$3"
  shift 3

  (
    "$@"
  ) > >(tee "$log_file") 2>&1 &
  local pid=$!

  monitor_process_with_heartbeat "$pid" "$label" "$log_file" "$HEARTBEAT_SEC" "$idle_timeout" "$EVENT_LOG"
  return $?
}

verify_log_indicates_success() {
  local log_file="$1"
  [[ -f "$log_file" ]] || return 1
  grep -Eq '(^|[[:space:]])PASSED([[:space:]]|$)' "$log_file" \
    && ! grep -Eq '(^|[[:space:]])FAILED([[:space:]]|$)' "$log_file"
}

run_claude_stream_with_watchdog() {
  local log_file="$1"
  local sidecar_pid claude_pid claude_pgid monitor_exit sidecar_exit

  : > "$log_file"
  (
    tail -n +1 -f "$log_file" 2>/dev/null | python3 "$SCRIPT_DIR/format-stream.py"
  ) &
  sidecar_pid=$!

  claude --dangerously-skip-permissions -p "$FULL_PROMPT" \
    --output-format=stream-json --include-partial-messages --verbose >"$log_file" 2>&1 &
  claude_pid=$!
  claude_pgid=$(process_pgid "$claude_pid")

  log_event "process" "spawned" "phase=$PHASE_GENERATE claude_pid=$claude_pid claude_pgid=${claude_pgid:-unknown} sidecar_pid=$sidecar_pid"

  set +e
  monitor_process_with_heartbeat \
    "$claude_pid" \
    "hook:test phase=$PHASE_GENERATE" \
    "$log_file" \
    "$HEARTBEAT_SEC" \
    "$GENERATE_IDLE_TIMEOUT_SEC" \
    "$EVENT_LOG" \
    "" \
    "$POST_RESULT_IDLE_SEC" \
    "$claude_pid,$sidecar_pid"
  monitor_exit=$?
  set -e

  kill_process_tree "$sidecar_pid"
  set +e
  wait "$sidecar_pid" 2>/dev/null
  sidecar_exit=$?
  set -e

  log_event "process" "closed" "phase=$PHASE_GENERATE claude_pid=$claude_pid sidecar_pid=$sidecar_pid sidecar_exit=$sidecar_exit monitor_exit=$monitor_exit"
  return "$monitor_exit"
}

preflight() {
  local missing
  missing=$(require_commands jq claude node yarn python3 || true)
  if [[ -n "$missing" ]]; then
    echo "$missing"
    log_event "test" "failed" "dependency_missing: $missing"
    return "$EXIT_DEP_MISSING"
  fi
  return 0
}

if [[ ! -f "$MANIFEST" ]]; then
  echo "ERROR: Manifest not found: $MANIFEST"
  log_event "test" "failed" "manifest_missing"
  exit "$EXIT_VALIDATION"
fi

preflight || exit $?

SPRINT_NAME=$(jq -r '.sprint' "$MANIFEST")
SPRINT_NUM=$(echo "$SPRINT_NAME" | grep -oE '^[0-9]+' || echo "")

TEST_DIR="$PROJECT_ROOT/backend/tests/sprint"
mkdir -p "$TEST_DIR"
TEST_FILE="$TEST_DIR/sprint_${SPRINT_NUM}.spec.ts"
TEST_LOG="$SPRINT_DIR/test.log"
VERIFY_LOG="$SPRINT_DIR/test-verify.log"
E2E_LOG="$SPRINT_DIR/e2e-test.log"
FAILURE_REPORT="$SPRINT_DIR/TEST_FAILURE_REPORT.md"

echo "Generating test suite for sprint: $SPRINT_NAME"
echo "Output: $TEST_FILE"
log_event "test" "running" "start sprint=$SPRINT_NAME"

CHUNKS_FILE="$SPRINT_DIR/chunks.json"
CHUNKS_CONTENT=""
if [[ -f "$CHUNKS_FILE" ]]; then
  CHUNKS_CONTENT=$(cat "$CHUNKS_FILE")
fi

ARTIFACTS=$(jq -r '.chunks[].artifacts[]' "$CHUNKS_FILE" 2>/dev/null | sort -u || echo "")
ACCEPTANCE=$(jq -r '.chunks[] | "## Chunk \(.id): \(.title)\n\(.acceptance_criteria | map("- " + .) | join("\n"))"' "$CHUNKS_FILE" 2>/dev/null || echo "")

ARTIFACT_CONTENT=""
for artifact in $ARTIFACTS; do
  FULL_PATH="$PROJECT_ROOT/$artifact"
  if [[ -f "$FULL_PATH" ]]; then
    EXT="${artifact##*.}"
    ARTIFACT_CONTENT+="### $artifact
\`\`\`$EXT
$(head -150 "$FULL_PATH")
\`\`\`

"
  fi
done

EXISTING_TESTS=""
EXISTING_TEST_FILES=$(find "$PROJECT_ROOT/backend/tests" -name "*.spec.ts" 2>/dev/null | head -3)
for test_file in $EXISTING_TEST_FILES; do
  if [[ -f "$test_file" ]]; then
    EXISTING_TESTS+="### $(basename "$test_file")
\`\`\`typescript
$(head -50 "$test_file")
\`\`\`

"
  fi
done

PROMPT_TEMPLATE=$(cat "$SCRIPT_DIR/prompts/test.md")
FULL_PROMPT=$(cat <<EOF_PROMPT
$PROMPT_TEMPLATE

## Sprint: $SPRINT_NAME

## Chunks & Acceptance Criteria:
$ACCEPTANCE

## Chunks JSON:
\`\`\`json
$CHUNKS_CONTENT
\`\`\`

## Files to Test:
$ARTIFACT_CONTENT

## Existing Test Patterns in This Project:
$EXISTING_TESTS

## Output Instructions:
1. Create test file: $TEST_FILE
2. Add script to backend/package.json: "test:sprint-$SPRINT_NUM": "node ace test --files tests/sprint/sprint_${SPRINT_NUM}.spec.ts"
3. Run tests and verify they pass
4. If tests fail, debug and fix (up to 3 attempts)
5. If tests STILL fail after 3 attempts: create $FAILURE_REPORT with details
6. Do NOT commit failing tests
7. Do NOT add "Generated with" or "Co-Authored-By" lines
8. Emit <promise>RALPH_CHUNK_COMPLETE</promise> only when this chunk is complete
EOF_PROMPT
)

# Phase 1: generate_tests
if phase_is_complete "$PHASE_GENERATE"; then
  echo "[phase:$PHASE_GENERATE] already complete; skipping"
else
  update_phase "$PHASE_GENERATE" "running"
  log_event "test_phase" "running" "$PHASE_GENERATE"

  set +e
  run_claude_stream_with_watchdog "$TEST_LOG"
  GENERATE_EXIT=$?
  set -e

  if [[ "$GENERATE_EXIT" -ne 0 ]]; then
    update_phase "$PHASE_GENERATE" "failed" "claude_exit_$GENERATE_EXIT"
    log_event "test_phase" "failed" "$PHASE_GENERATE claude_exit=$GENERATE_EXIT"
    exit "$EXIT_VALIDATION"
  fi

  if [[ -f "$FAILURE_REPORT" ]]; then
    update_phase "$PHASE_GENERATE" "failed" "failure_report_created"
    log_event "test_phase" "failed" "$PHASE_GENERATE failure_report_created"
    echo "TEST GENERATION INCOMPLETE"
    echo "Failure report created: $FAILURE_REPORT"
    head -20 "$FAILURE_REPORT" || true
    exit "$EXIT_VALIDATION"
  fi

  if [[ ! -f "$TEST_FILE" ]]; then
    update_phase "$PHASE_GENERATE" "failed" "missing_test_file"
    log_event "test_phase" "failed" "$PHASE_GENERATE missing_test_file"
    echo "TEST GENERATION FAILED: missing $TEST_FILE"
    exit "$EXIT_VALIDATION"
  fi

  update_phase "$PHASE_GENERATE" "done"
  log_event "test_phase" "ok" "$PHASE_GENERATE"
fi

# Phase 2: verify_backend_tests
if phase_is_complete "$PHASE_VERIFY"; then
  echo "[phase:$PHASE_VERIFY] already complete; skipping"
else
  update_phase "$PHASE_VERIFY" "running"
  log_event "test_phase" "running" "$PHASE_VERIFY"

  if ! jq -e --arg key "test:sprint-$SPRINT_NUM" '.scripts[$key]' "$PROJECT_ROOT/backend/package.json" >/dev/null 2>&1; then
    update_phase "$PHASE_VERIFY" "failed" "missing_test_script"
    log_event "test_phase" "failed" "$PHASE_VERIFY missing_test_script"
    exit "$EXIT_VALIDATION"
  fi

  set +e
  run_monitored_command \
    "backend-tests:sprint-$SPRINT_NUM" \
    "$VERIFY_LOG" \
    "$BACKEND_TEST_IDLE_TIMEOUT_SEC" \
    bash -lc "cd '$PROJECT_ROOT/backend' && yarn test:sprint-$SPRINT_NUM"
  VERIFY_EXIT=$?
  set -e

  if [[ "$VERIFY_EXIT" -eq "$EXIT_IDLE_TIMEOUT" ]]; then
    if verify_log_indicates_success "$VERIFY_LOG"; then
      echo "WARNING: backend test runner remained alive after PASS output; treating phase as successful"
      log_event "test_phase" "warning" "$PHASE_VERIFY idle_timeout_after_pass_output"
      VERIFY_EXIT=0
    else
      update_phase "$PHASE_VERIFY" "failed" "idle_timeout"
      log_event "test_phase" "failed" "$PHASE_VERIFY idle_timeout"
      exit "$EXIT_IDLE_TIMEOUT"
    fi
  fi

  if [[ "$VERIFY_EXIT" -ne 0 ]]; then
    update_phase "$PHASE_VERIFY" "failed" "backend_tests_failed"
    log_event "test_phase" "failed" "$PHASE_VERIFY backend_tests_failed exit=$VERIFY_EXIT"
    exit "$EXIT_VALIDATION"
  fi

  update_phase "$PHASE_VERIFY" "done"
  log_event "test_phase" "ok" "$PHASE_VERIFY"
fi

# Phase 3: run_e2e
IS_FRONTEND=false
if jq -r '.chunks[].artifacts[]' "$CHUNKS_FILE" 2>/dev/null | grep -q '^frontend/'; then
  IS_FRONTEND=true
fi

if [[ "$IS_FRONTEND" != "true" ]]; then
  update_phase "$PHASE_E2E" "skipped" "not_applicable"
  log_event "test_phase" "skipped" "$PHASE_E2E not_applicable"
else
  if phase_is_complete "$PHASE_E2E"; then
    echo "[phase:$PHASE_E2E] already complete; skipping"
  else
    update_phase "$PHASE_E2E" "running"
    log_event "test_phase" "running" "$PHASE_E2E"

    if ! command -v npx >/dev/null 2>&1; then
      update_phase "$PHASE_E2E" "failed" "missing_npx"
      log_event "test_phase" "failed" "$PHASE_E2E missing_npx"
      exit "$EXIT_DEP_MISSING"
    fi

    (cd "$PROJECT_ROOT/backend" && node ace seed:e2e >/dev/null 2>&1) || true

    set +e
    run_monitored_command \
      "playwright-e2e" \
      "$E2E_LOG" \
      "$E2E_IDLE_TIMEOUT_SEC" \
      bash -lc "cd '$PROJECT_ROOT/frontend' && npx playwright test"
    E2E_EXIT=$?
    set -e

    if [[ "$E2E_EXIT" -eq "$EXIT_IDLE_TIMEOUT" ]]; then
      update_phase "$PHASE_E2E" "failed" "idle_timeout"
      log_event "test_phase" "failed" "$PHASE_E2E idle_timeout"
      exit "$EXIT_IDLE_TIMEOUT"
    fi

    if [[ "$E2E_EXIT" -ne 0 ]]; then
      update_phase "$PHASE_E2E" "failed" "e2e_failed"
      log_event "test_phase" "failed" "$PHASE_E2E e2e_failed exit=$E2E_EXIT"
      exit "$EXIT_VALIDATION"
    fi

    update_phase "$PHASE_E2E" "done"
    log_event "test_phase" "ok" "$PHASE_E2E"
  fi
fi

echo ""
echo "=========================================="
echo "TEST SUITE COMPLETE"
echo "=========================================="
echo "Test file: $TEST_FILE"
echo "Verify log: $VERIFY_LOG"
if [[ "$IS_FRONTEND" == "true" ]]; then
  echo "E2E log: $E2E_LOG"
fi

log_event "test" "ok" "all phases complete"
exit "$EXIT_OK"
